{
  "expo": {
    "name": "ONCE MEDIA",
    "slug": "once-media-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-font",
      "expo-video"
    ],
    "android": {
      "softwareKeyboardLayoutMode": "pan"
    }
  }
}